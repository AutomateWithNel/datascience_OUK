{
  "id": 932,
  "name": "Module 9: Handling Time Series Data",
  "visible": 1,
  "summary": "<div class=\"jumbotron jumbotron-fluid text-white shadow\" style=\"background: linear-gradient(to top,  var(--secondary), var(--primary),var(--info)); padding: 1em; margin-bottom: 1em;\">\r\n    <h5 style=\"color: white;\"></h5>\r\n    <div class=\"container\" style=\"color: white;\">\r\n        <p class=\"lead\"><span id=\"label_content_504745\"><strong><strong><span><span><span><span id=\"label_content_504745\">Module </span>Developer:&nbsp; Selina Ochukut</span></span></span><span><span><br></span></span></strong></strong></span></p>\r\n        <p><strong> Instructional Hours: </strong> 4 hours</p>\r\n        <hr class=\"my-4 border-white\">\r\n    </div>\r\n    <p style=\"color: white;\"></p>\r\n    <div class=\"box py-3 generalbox oukbook_content oukbook_introduction_chapter\" style=\"\">\r\n        <div class=\"oukbook_chapter_title_div\" style=\"color: white;\">\r\n            <div class=\"oukbook_chapter_booktitle2\" align=\"right\">DSC201: Python for Data Science</div>\r\n        </div>\r\n        <div class=\"module-container\" style=\"\">\r\n            <div class=\"timeline\" style=\"\">\r\n                <div class=\"timeline-container primary\" style=\"\">\r\n                    <div class=\"timeline-icon\" style=\"color: white;\"><i class=\"fa fa-edit\"></i></div>\r\n                    <div class=\"timeline-body\" style=\"\">\r\n                        <h4 class=\"timeline-title\" style=\"color: white;\"><span class=\"badge\">Module Overview</span></h4>\r\n                        <p style=\"\">This module provides a comprehensive introduction to handling time series data, a crucial aspect of data analysis in various domains such as finance, economics, and environmental science. You will learn about date and time data types, tools, and techniques for processing and analyzing time series data effectively. You will cover data ranges, frequencies, shifting, time zone handling, resampling, frequency conversion, and moving window functions.<br></p>\r\n                    </div>\r\n                </div>\r\n                <div class=\"timeline-container danger\" style=\"color: white;\">\r\n                    <div class=\"timeline-body\">\r\n                        <table class=\"custombox-definition\" cellspacing=\"0\" style=\"width: 100%;\">\r\n                            <tbody>\r\n                                <tr valign=\"top\">\r\n                                    <td class=\"custombox-header-thumb definition\" width=\"2%\"></td>\r\n                                    <td class=\"custombox-content definition\" width=\"98%\">\r\n                                        <div class=\"custombox-container definition\" style=\"padding-left: 10px;\">\r\n                                            <div class=\"custombox-flexline definition\">\r\n                                                <div class=\"custombox-header-caption definition\" width=\"98%\" style=\"margin-bottom: 10px;\">\r\n                                                    <h4>Learning Outcomes</h4>\r\n                                                </div>\r\n                                            </div>\r\n                                            <div class=\"custombox-flexline definition\">\r\n                                                <p style=\"margin-bottom: 10px;\"><span><strong></strong></span><span><strong>By the end of this module, you should be able to:</strong></span></p>\r\n                                            </div>\r\n                                            <div class=\"custombox-flexline definition\">\r\n                                                <ol class=\"customlabel-subdefinition definition HELM_parts\" style=\"padding-left: 40px;\">\r\n                                                    <li><span> Describe the fundamental concepts and tools for handling time series data, including date and time data types, data ranges, frequencies, and time zone handling\r\n</span></li>\r\n                                                    <li><span> Explain the significance and applications of resampling and frequency conversion in time series analysis\r\n.</span></li>\r\n                                                    <li><span> Apply shifting and moving window functions to manipulate and analyze time series data effectively.</span></li>\r\n                                                    <li><span>Interpret time series data after applying various data handling techniques, such as resampling and moving window functions.</span></li>\r\n                                                </ol>\r\n                                            </div>\r\n                                        </div>\r\n                                    </td>\r\n                                </tr>\r\n                            </tbody>\r\n                        </table>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n<div></div>",
