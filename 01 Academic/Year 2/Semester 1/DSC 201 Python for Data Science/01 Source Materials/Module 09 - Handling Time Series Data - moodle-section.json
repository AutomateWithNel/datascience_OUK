      "description": "<!-- customlabeltype_worktodo/template -->\n\n\n<!-- mod_customlabel/start -->\n<table class=\"custombox-worktodo\" cellspacing=\"0\" width=\"100%\">\n\n    <tr valign=\"top\">\n        <td class=\"custombox-header-thumb worktodo default \" width=\"2%\">\n        </td>\n        <td class=\"custombox-content worktodo \" width=\"98%\">\n<!-- /mod_customlabel/start -->\n    <div class=\"custombox-container worktodo\">\n        <div class=\"custombox-flexline worktodo\">\n            <div class=\"custombox-header-caption worktodo default\">\n                <h4>Work to Do</h4>\n            </div>\n        </div>\n\n        <div class=\"custombox-flexline worktodo\">\n            <div class=\"custombox-worktype worktodo\">\n            </div>\n            <div class=\"custombox-timeexpected worktodo\" align=\"right\" width=\"40\">\n                <img src=\"https://somas.ouk.ac.ke/theme/image.php/uonbi/customlabeltype_worktodo/1780665068/clock\" /> 4 hours\n            </div>\n        </div>\n\n        <div class=\"custombox-flexline worktodo\">\n        </div>\n\n        <div class=\"custombox-flexline worktodo\">\n            <div class=\"custombox-inner-content worktodo\">\n                <ol class=\"HELM_parts\" dir=\"ltr\">\r\n    <li style=\"text-align:left;\">Watch a Curated Lecture Video</li>\r\n    <li style=\"text-align:left;\">Review power presentation </li>\r\n    <li style=\"text-align:left;\">Watch lecture related videos</li>\r\n    <li style=\"text-align:left;\">Complete participation assignment:&nbsp; Quiz 1</li>\r\n    <li style=\"text-align:left;\">Complete personal introduction video</li>\r\n    <li style=\"text-align:left;\">Review concept assignment : Quiz 2</li>\r\n</ol>\n            </div>\n        </div>\n    </div>\n\n\n\n<!-- mod_customlabel/end -->\n        </td>\n    </tr>\n</table>\n<!-- /mod_customlabel/end -->\n<!-- /customlabeltype_worktodo/template -->",
